# ── SHARED ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── DATABASES ────────────────────────────────────────────
AUTH_DATABASE_URL=postgresql://user:password@localhost:5432/auth_db
EVENT_DATABASE_URL=postgresql://user:password@localhost:5432/event_db
LOCATION_DATABASE_URL=postgresql://user:password@localhost:5432/location_db
MEDIA_DATABASE_URL=postgresql://user:password@localhost:5432/media_db
GAMIFICATION_DATABASE_URL=postgresql://user:password@localhost:5432/gamification_db
NOTIFICATION_DATABASE_URL=postgresql://user:password@localhost:5432/notification_db
PAYMENT_DATABASE_URL=postgresql://user:password@localhost:5432/payment_db

# ── REDIS ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── KAFKA ────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=cleannation

# ── AUTH ─────────────────────────────────────────────────
JWT_PRIVATE_KEY=your_rs256_private_key_here
JWT_PUBLIC_KEY=your_rs256_public_key_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_secret

# ── MEDIA / STORAGE ──────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=cleannation-media
R2_PUBLIC_URL=https://media.cleannation.app

# ── PAYMENT ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── NOTIFICATIONS ─────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your_resend_api_key
PUSH_VAPID_PUBLIC=your_vapid_public_key
PUSH_VAPID_PRIVATE=your_vapid_private_key

# ── SENTRY ───────────────────────────────────────────────
SENTRY_DSN=

# ── SERVICE PORTS ─────────────────────────────────────────
GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
EVENT_SERVICE_PORT=3002
LOCATION_SERVICE_PORT=3003
MEDIA_SERVICE_PORT=3004
GAMIFICATION_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
PAYMENT_SERVICE_PORT=3007

# ── INTERNAL gRPC PORTS ───────────────────────────────────
MEDIA_GRPC_PORT=50051
